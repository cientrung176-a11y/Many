{
  "expo": {
    "name": "Thị Niễu",
    "slug": "thi-nieu",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "lieu-an-cuc",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lieu.ancuc"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "com.lieu.ancuc"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "App cần truy cập ảnh để đính kèm hoá đơn",
          "cameraPermission": "App cần camera để chụp hoá đơn"
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-quick-actions",
        {
          "androidIcons": {},
          "items": [
            {
              "id": "add_expense",
              "title": "Thêm chi tiêu",
              "subtitle": "Ghi lại khoản chi mới",
              "icon": "add_circle",
              "params": { "href": "/add-expense" }
            },
            {
              "id": "view_expenses",
              "title": "Xem chi tiêu",
              "subtitle": "Danh sách chi tiêu",
              "icon": "list",
              "params": { "href": "/(tabs)/expenses" }
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
