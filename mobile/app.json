{
  "expo": {
    "name": "Thị Niễu",
    "slug": "spendwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "lieu-an-cuc",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lieu.ancuc",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "com.lieu.ancuc",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "App cần truy cập ảnh để đính kèm hoá đơn",
          "cameraPermission": "App cần camera để chụp hoá đơn"
        }
      ],
      "expo-font",
      "expo-asset",
      "./modules/widget/plugin/withWidget",
      [
        "expo-quick-actions",
        {
          "iosActions": [
            {
              "id": "add_expense",
              "title": "Thêm chi tiêu",
              "subtitle": "Ghi lại khoản chi mới",
              "icon": "compose",
              "params": { "href": "/add-expense" }
            },
            {
              "id": "view_expenses",
              "title": "Xem chi tiêu",
              "subtitle": "Danh sách chi tiêu",
              "icon": "search",
              "params": { "href": "/(tabs)/expenses" }
            }
          ],
          "androidActions": [
            {
              "id": "add_expense",
              "title": "Thêm chi tiêu",
              "icon": "@drawable/ic_add",
              "intent": "lieu-an-cuc://add-expense"
            },
            {
              "id": "view_expenses",
              "title": "Xem chi tiêu",
              "icon": "@drawable/ic_list",
              "intent": "lieu-an-cuc://expenses"
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5b52eea4-8dae-4084-a31c-1c94068a3757"
      }
    },
    "owner": "cien02s-organization",
    "experiments": {
      "typedRoutes": true
    }
  }
}
